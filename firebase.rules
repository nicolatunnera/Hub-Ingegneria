╔══════════════════════════════════════════════════════╗
║  ENGINEERING CLOUD HUB — FIRESTORE SECURITY RULES   ║
║  Deploy in Firebase Console → Firestore → Rules      ║
╚══════════════════════════════════════════════════════╝

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── REGOLA BASE: solo utenti autenticati ──
    // L'app fa signInAnonymously() all'avvio, quindi ogni
    // sessione ha request.auth != null.
    // Chiunque chiami Firebase senza passare dall'app è bloccato.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── REGOLE FUTURE (quando passerai a email/password) ──
    // Esempio: solo l'owner può scrivere su accountsHub
    //
    // match /accountsHub/{doc} {
    //   allow read: if request.auth != null;
    //   allow write: if request.auth.uid == 'UID_DELL_ING';
    // }
    //
    // Esempio: solo chi ha creato una nota può eliminarla
    //
    // match /notesHub/{doc} {
    //   allow read: if request.auth != null;
    //   allow create: if request.auth != null;
    //   allow delete: if request.resource.data.createdBy == request.auth.uid;
    // }
  }
}


─── ISTRUZIONI ─────────────────────────────────────────
1. Vai su https://console.firebase.google.com
2. Apri il progetto "hub-ingegneria"
3. Firestore → Rules → incolla le regole qui sopra → PUBBLICA
4. Auth → Sign-in method → abilita "Anonimo" (se non già attivo)

📌 NOTA: L'app usa auth anonimo (signInAnonymously).
    Questo basta a soddisfare request.auth != null.
    In futuro, per regole più granulari, passa a email/password.

📌 Per trovare l'UID di un utente:
    Firebase Console → Authentication → cerca utente → copia UID
